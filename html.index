<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>منصة التميز للبكالوريا</title>
    <style>
        /* تصميم فخم وعصري (لوحة ألوان داكنة وذهبية) */
        :root {
            --bg-color: #0f172a;
            --card-bg: #1e293b;
            --accent-gold: #fbbf24;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --success: #10b981;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            padding: 20px;
        }

        header {
            text-align: center;
            padding: 40px 20px;
            background: linear-gradient(135deg, #1e293b 0%, #111827 100%);
            border-radius: 15px;
            border: 1px solid rgba(251, 191, 36, 0.2);
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        header h1 {
            color: var(--accent-gold);
            font-size: 2.5rem;
            margin-bottom: 10px;
            text-shadow: 0 2px 10px rgba(251, 191, 36, 0.3);
        }

        header p {
            color: var(--text-muted);
            font-size: 1.1rem;
        }

        /* تقسيم الخانات */
        .grid-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 30px;
        }

        @media (min-width: 992px) {
            .grid-container {
                grid-template-columns: 1fr 1fr;
            }
            .full-width {
                grid-column: span 2;
            }
        }

        .card {
            background-color: var(--card-bg);
            border-radius: 15px;
            padding: 25px;
            border: 1px solid rgba(255,255,255,0.05);
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
            transition: transform 0.3s ease;
        }

        .card:hover {
            transform: translateY(-5px);
            border-color: rgba(251, 191, 36, 0.3);
        }

        .card-title {
            color: var(--accent-gold);
            font-size: 1.4rem;
            margin-bottom: 20px;
            border-bottom: 2px solid rgba(251, 191, 36, 0.2);
            padding-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* الخانة 1: لوحة التحكم والتقدم */
        .progress-box {
            text-align: center;
            padding: 20px;
        }
        
        .counter-text {
            font-size: 1.2rem;
            margin-bottom: 10px;
        }

        /* الخانة 2: جدول تنظيم الوقت */
        .timetable {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        .timetable th, .timetable td {
            border: 1px solid rgba(255,255,255,0.1);
            padding: 12px;
            text-align: right;
        }

        .timetable th {
            background-color: rgba(251, 191, 36, 0.1);
            color: var(--accent-gold);
        }

        .timetable tr:nth-child(even) {
            background-color: rgba(255,255,255,0.02);
        }

        .subject-tag {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.85rem;
            font-weight: bold;
        }
        .tag-main { background-color: #b91c1c; color: white; } /* أساسية */
        .tag-second { background-color: #0369a1; color: white; } /* ثانوية */
        .tag-rest { background-color: #047857; color: white; } /* مراجعة/راحة */

        /* الخانة 3: تتبع البكالوريات */
        .scroll-table {
            max-height: 400px;
            overflow-y: auto;
            padding-left: 5px;
        }

        .bac-table {
            width: 100%;
            border-collapse: collapse;
        }

        .bac-table th, .bac-table td {
            padding: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            text-align: center;
        }

        .bac-table th {
            position: sticky;
            top: 0;
            background-color: var(--card-bg);
            color: var(--accent-gold);
            z-index: 1;
        }

        .checkbox-container {
            display: block;
            position: relative;
            cursor: pointer;
            font-size: 22px;
            user-select: none;
        }

        /* تخصيص الـ Checkbox لتبدو فخمة */
        .bac-table input[type="checkbox"] {
            width: 20px;
            height: 20px;
            accent-color: var(--accent-gold);
            cursor: pointer;
        }

        /* الخانة 4: نصائح وحكمة اليوم */
        .quote-box {
            font-style: italic;
            color: var(--text-muted);
            border-right: 4px solid var(--accent-gold);
            padding-right: 15px;
            margin-top: 15px;
            font-size: 1.1rem;
        }

        .tips-list {
            margin-top: 15px;
            list-style-type: square;
            padding-right: 20px;
            color: var(--text-muted);
        }

        .tips-list li {
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

    <header>
        <h1>مَنصَّةُ التَّمَيُّزِ وَالتَّفَوُّقِ</h1>
        <p>بوابتك الذكية لتنظيم الوقت واجتياز شهادة البكالوريا بمعدل ممتاز إن شاء الله</p>
    </header>

    <div class="grid-container">

        <div class="card">
            <div class="card-title">📊 لوحة التحكم ومعدل الإنجاز</div>
            <div class="progress-box">
                <p class="counter-text">عدد مواضيع البكالوريا التي قمت بحلها حتى الآن:</p>
                <h2 id="solved-count" style="font-size: 3rem; color: var(--success); margin: 10px 0;">0</h2>
                <p style="color: var(--text-muted);">كل خطوة صغيرة تقربك من هدفك الشغل الشاغل. واصل العطاء!</p>
            </div>
        </div>

        <div class="card">
            <div class="card-title">💡 كبسولة النجاح والتحفيز</div>
            <div class="quote-box">
                "النجاح ليس صدفة، بل هو نتاج تنظيم، عمل مستمر، وإيمان مطلق بالقدرات."
            </div>
            <ul class="tips-list">
                <li>ابدأ بالمواد الأساسية في الأوقات التي يكون فيها استيعابك عاليًا (كالصباح الباكر).</li>
                <li>حل البكالوريات السابقة هو المفتاح السري لفهم عقلية الأستاذ المصحح.</li>
                <li>حافظ على فترات راحة قصيرة (5 دقائق) كل 25 دقيقة دراسة (تقنية البومودورو).</li>
            </ul>
        </div>

        <div class="card full-width">
            <div class="card-title">📅 خطة تنظيم الوقت المقترحة (النموذج اليومي المتوازن)</div>
            <p style="color: var(--text-muted); margin-bottom: 15px;">جدول مرن يعتمد على فترات ذروة التركيز، مصمم خصيصاً لطلبة البكالوريا:</p>
            <table class="timetable">
                <thead>
                    <tr>
                        <th>الفترة الزمنية</th>
                        <th>النشاط والدراسة</th>
                        <th>نوع المادة</th>
                        <th>الهدف</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>05:00 - 06:30 (بعد الفجر)</td>
                        <td>حفظ وتثقيف (شريعة، تاريخ وجغرافيا، فلسفة)</td>
                        <td><span class="subject-tag tag-second">مواد الحفظ</span></td>
                        <td>استغلال أعلى مستويات الذاكرة قصيرة المدى.</td>
                    </tr>
                    <tr>
                        <td>08:00 - 11:00 (الصباح)</td>
                        <td>مادة أساسية 1 (رياضيات / فيزياء / علوم / أدب حسب شعبتك)</td>
                        <td><span class="subject-tag tag-main">مادة أساسية</span></td>
                        <td>حل تمارين معمقة واستيعاب المفاهيم المعقدة.</td>
                    </tr>
                    <tr>
                        <td>14:00 - 16:30 (المساء)</td>
                        <td>لغات (فرنسية، إنجليزية، عربية) أو مراجعة خفيفة</td>
                        <td><span class="subject-tag tag-second">مواد لغات</span></td>
                        <td>تطوير مهارات التعبير وحل النصوص والتمارين السريعة.</td>
                    </tr>
                    <tr>
                        <td>17:30 - 19:30 (قبل العشاء)</td>
                        <td>مادة أساسية 2 أو تكملة لتمارين مستعصية</td>
                        <td><span class="subject-tag tag-main">مادة أساسية</span></td>
                        <td>التركيز على نقاط الضعف وسد الثغرات.</td>
                    </tr>
                    <tr>
                        <td>21:00 - 22:00 (الليل)</td>
                        <td>تقييم اليوم + حل موضوع بكالوريا جزئي + تنظيم حقيبة الغد</td>
                        <td><span class="subject-tag tag-rest">تخطيط واسترخاء</span></td>
                        <td>نوم مبكر ومريح لإعادة شحن الدماغ.</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="card full-width">
            <div class="card-title">✅ سجل إنجاز البكالوريات السابقة (2012 - 2025)</div>
            <p style="color: var(--text-muted); margin-bottom: 15px;">ضع علامة صح بجانب كل حولية تقوم بحلها كاملاً. سيتم حفظ تقدمك تلقائياً في المتصفح!</p>
            
            <div class="scroll-table">
                <table class="bac-table">
                    <thead>
                        <tr>
                            <th>السنة</th>
                            <th>الرياضيات</th>
                            <th>العلوم الفيزيائية</th>
                            <th>العلوم الطبيعية / الفلسفة</th>
                            <th>اللغة العربية</th>
                            <th>التاريخ والجغرافيا</th>
                        </tr>
                    </thead>
                    <tbody id="bac-tbody">
                        </tbody>
                </table>
            </div>
        </div>

    </div>

    <script>
        // توليد جدول البكالوريات برمجياً لتوفير مساحة الكود
        const tbody = document.getElementById('bac-tbody');
        const subjects = ['math', 'physics', 'science', 'arabic', 'history'];
        
        // توليد السنوات من 2025 نزولاً إلى 2012
        for (let year = 2025; year >= 2012; year--) {
            const tr = document.createElement('tr');
            
            // عمود السنة
            const tdYear = document.createElement('td');
            tdYear.textContent = year;
            tdYear.style.fontWeight = 'bold';
            tdYear.style.color = 'var(--accent-gold)';
            tr.appendChild(tdYear);
            
            // أعمدة المواد
            subjects.forEach(sub => {
                const td = document.createElement('td');
                const checkbox = document.createElement('input');
                checkbox.type = 'checkbox';
                checkbox.id = `bac-${year}-${sub}`;
                
                // إضافة حدث عند الضغط لحفظ الحالة وتحديث العداد
                checkbox.addEventListener('change', updateProgress);
                
                td.appendChild(checkbox);
                tr.appendChild(td);
            });
            
            tbody.appendChild(tr);
        }

        // دالة لتحديث العداد وحفظ البيانات في متصفح المستخدم (LocalStorage)
        function updateProgress() {
            let solvedCount = 0;
            const checkboxes = document.querySelectorAll('.bac-table input[type="checkbox"]');
            
            checkboxes.forEach(cb => {
                if (cb.checked) {
                    solvedCount++;
                    localStorage.setItem(cb.id, 'true');
                } else {
                    localStorage.removeItem(cb.id);
                }
            });
            
            document.getElementById('solved-count').textContent = solvedCount;
        }

        // دالة لتحميل البيانات المحفوظة سابقاً عند فتح الموقع
        function loadProgress() {
            const checkboxes = document.querySelectorAll('.bac-table input[type="checkbox"]');
            let solvedCount = 0;
            
            checkboxes.forEach(cb => {
                if (localStorage.getItem(cb.id) === 'true') {
                    cb.checked = true;
                    solvedCount++;
                }
            });
            
            document.getElementById('solved-count').textContent = solvedCount;
        }

        // تشغيل دالة التحميل عند بدء تشغيل الصفحة
        window.onload = loadProgress;
    </script>
</body>
</html>
